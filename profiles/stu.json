{
  "name": "汕头大学 (STU)",
  "description": "汕头大学校园网认证，支持 IPv4 (a.stu.edu.cn) 和 IPv6 (6.stu.edu.cn)",
  "detect": {
    "dns_domains": ["a.stu.edu.cn"],
    "test_url": "http://a.stu.edu.cn/",
    "offline_keywords": ["login", "portal", "认证"],
    "online_keywords": ["success", "已在线", "online"]
  },
  "login": {
    "method": "POST",
    "url": "http://a.stu.edu.cn/eportal/InterFace.do?method=login",
    "params": {
      "userId": "{username}",
      "password": "{password}",
      "service": "internet",
      "queryString": "wlanuserip%3D{wlan_ip}",
      "operatorPwd": "",
      "operatorUserId": "",
      "validcode": "",
      "passwordEncrypt": "false"
    },
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "success_keywords": ["success", "successful", "认证成功"],
    "failure_keywords": ["fail", "error", "密码错误", "账号不存在"],
    "encoding": "utf-8"
  },
  "ipv6_login": {
    "enabled": true,
    "method": "POST",
    "url": "http://6.stu.edu.cn/eportal/InterFace.do?method=login",
    "params": {
      "userId": "{username}",
      "password": "{password}",
      "service": "internet",
      "queryString": "wlanuserip%3D{wlan_ip}",
      "operatorPwd": "",
      "operatorUserId": "",
      "validcode": "",
      "passwordEncrypt": "false"
    },
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "success_keywords": ["success", "successful"]
  },
  "logout": {
    "method": "POST",
    "url": "http://a.stu.edu.cn/eportal/InterFace.do?method=logout",
    "params": {},
    "headers": {}
  }
}
