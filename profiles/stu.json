{
  "name": "汕头大学 (STU)",
  "description": "汕头大学校园网认证 Dr.COM 6.x ac_portal",
  "detect": {
    "dns_domains": ["a.stu.edu.cn"],
    "test_url": "https://a.stu.edu.cn/",
    "offline_keywords": ["ac_portal", "login", "portal", "认证", "pwdLogin"],
    "online_keywords": ["success", "已在线", "online", "注销"]
  },
  "login": {
    "method": "POST",
    "url": "https://a.stu.edu.cn/ac_portal/login.php",
    "params": {
      "opr": "pwdLogin",
      "userName": "{username}",
      "pwd": "{password}",
      "ipv4or6": "",
      "rememberPwd": "1"
    },
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
      "X-Requested-With": "XMLHttpRequest"
    },
    "success_keywords": ["success", "successful", "认证成功", "登录成功"],
    "failure_keywords": ["fail", "error", "密码错误", "账号不存在"],
    "encoding": "utf-8"
  },
  "ipv6_login": {
    "enabled": false,
    "method": "POST",
    "url": "",
    "params": {},
    "headers": {}
  },
  "logout": {
    "method": "POST",
    "url": "https://a.stu.edu.cn/ac_portal/login.php",
    "params": {
      "opr": "pwdLogout"
    },
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
      "X-Requested-With": "XMLHttpRequest"
    }
  }
}
