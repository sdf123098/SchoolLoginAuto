{
  "name": "深澜通用 (Srun Generic)",
  "description": "深澜宽带认证系统通用配置，适用于多数使用深澜系统的学校",
  "detect": {
    "dns_domains": [],
    "test_url": "http://10.0.0.55/",
    "offline_keywords": ["login", "portal", "认证", "srun"],
    "online_keywords": ["success", "已在线"]
  },
  "login": {
    "method": "POST",
    "url": "http://10.0.0.55/cgi-bin/srun_portal",
    "params": {
      "action": "login",
      "username": "{username}",
      "password": "{password}",
      "ac_id": "1"
    },
    "headers": {
      "Content-Type": "application/x-www-form-urlencoded"
    },
    "success_keywords": ["success", "login_ok", "认证成功"],
    "failure_keywords": ["fail", "error", "密码错误"],
    "encoding": "utf-8"
  },
  "ipv6_login": {
    "enabled": false,
    "method": "POST",
    "url": "",
    "params": {},
    "headers": {}
  },
  "logout": {
    "method": "POST",
    "url": "http://10.0.0.55/cgi-bin/srun_portal",
    "params": {"action": "logout"},
    "headers": {}
  }
}
